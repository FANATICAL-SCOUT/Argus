# ── Python cache ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────
venv/
env/
.venv/
.env

# ── OS junk ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs and temp files ───────────────────────────────────────────────
*.log
*.tmp
*.temp
*.bak
*.swp

# ── Scan output files (generated at runtime) ─────────────────────────
report.txt
records/
*.txt.scan

# ── Runtime data (generated at scan time — do not commit) ────────────
data/records/
data/database/
data/exports/
data/logs/
# Keep directory markers and the vuln DB
!data/records/.gitkeep
!data/database/.gitkeep
!data/exports/.gitkeep
!data/logs/.gitkeep
!data/vuln_database.json

# ── Self-hosted vendor assets (large, downloaded separately) ─────────
frontend/static/vendor/
frontend/static/fonts/
frontend/static/icons/
!frontend/static/vendor/.gitkeep
!frontend/static/fonts/.gitkeep
!frontend/static/icons/.gitkeep
!frontend/static/images/.gitkeep

# ── Build artifacts ───────────────────────────────────────────────────
*.egg-info/
build/
dist/
.eggs/

# ── IDE files ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Sensitive files ───────────────────────────────────────────────────
*.key
*.pem
*.crt
*.env
secrets.json
data/users.json

# ── Internal notes (not for public repo) ─────────────────────────────
*prompt*.txt
docs/V2_DASHBOARD_BRIEF.md
.mac_original

# ── Testing / coverage ────────────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/

# ── Binary / archive ─────────────────────────────────────────────────
*.bin
*.exe
*.dll
*.zip